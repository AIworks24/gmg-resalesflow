# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Never commit this key. It bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Only needed to run send-receipts.js against the test project (--test)
SUPABASE_URL_TEST=https://your-test-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY_TEST=your-test-service-role-key

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://resales.gmgva.com
NEXT_PUBLIC_APP_NAME=GMG ResaleFlow

# Email Configuration (for Zapier integration)
WEBHOOK_SECRET=gmg_resale_webhook_2024

# Stripe Configuration (add when ready)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...
