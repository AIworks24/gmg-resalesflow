{
  "crons": [
    {
      "path": "/api/check-expiring-documents",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/send-daily-email",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/check-deadline-reminders",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/check-correction-expiry",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/check-stuck-applications",
      "schedule": "0 11 * * *"
    }
  ],
  "functions": {
    "pages/api/check-expiring-documents.js": {
      "maxDuration": 30
    },
    "pages/api/send-daily-email.js": {
      "maxDuration": 30
    },
    "pages/api/check-deadline-reminders.js": {
      "maxDuration": 30
    },
    "pages/api/check-correction-expiry.js": {
      "maxDuration": 60
    },
    "pages/api/webhooks/stripe.js": {
      "maxDuration": 300
    },
    "pages/api/check-stuck-applications.js": {
      "maxDuration": 30
    }
  }
}